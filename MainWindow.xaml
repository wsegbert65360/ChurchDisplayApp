<Window x:Class="ChurchDisplayApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Church Display Control"
        Height="700"
        Width="1200"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        Icon="icon.ico">

    <Window.InputBindings>
        <KeyBinding Key="Space" Command="{Binding NextCommand}" />
        <KeyBinding Key="Right" Command="{Binding NextCommand}" />
        <KeyBinding Key="Left" Command="{Binding PreviousCommand}" />
        <KeyBinding Key="B" Command="{Binding BlankCommand}" />
        <KeyBinding Key="F11" Command="{Binding ToggleFullscreenCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ExitFullscreenCommand}" />
    </Window.InputBindings>
    
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280" MinWidth="220" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" MinWidth="360" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════ SIDEBAR ═══════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Add Button -->
                    <RowDefinition Height="Auto" /> <!-- Font Size -->
                    <RowDefinition Height="*" />    <!-- Playlist -->
                    <RowDefinition Height="Auto" /> <!-- Media Controls -->
                </Grid.RowDefinitions>

                <!-- Add Media Button -->
                <Button Grid.Row="0" 
                        Style="{StaticResource ModernButtonStyle}" 
                        Click="AddFiles_Click"
                        Margin="15,5" 
                        Padding="8,4"
                        HorizontalAlignment="Stretch"
                        Height="32">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource AddFilesIconData}" Fill="{StaticResource TextBrush}" Stretch="Uniform" Width="10" Height="10" Margin="0,0,8,0" />
                        <TextBlock Text="ADD MEDIA" FontSize="10" FontWeight="Bold" />
                    </StackPanel>
                </Button>

                <!-- Font Size Slider -->
                <DockPanel Grid.Row="1" Margin="15,10,15,5">
                    <TextBlock Text="SERVICE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="A" FontSize="8" VerticalAlignment="Center" Opacity="0.5" Margin="0,0,4,0" />
                        <Slider Width="50" Minimum="6" Maximum="24" Value="{Binding PlaylistFontSize, Mode=TwoWay}" VerticalAlignment="Center" SmallChange="1" />
                        <TextBlock Text="A" FontSize="12" VerticalAlignment="Center" Opacity="0.8" Margin="4,0,0,0" />
                    </StackPanel>
                </DockPanel>

                <!-- Playlist ListBox -->
                <ListBox x:Name="PlaylistListBox"
                         Grid.Row="2"
                         ItemsSource="{Binding PlaylistItems}"
                         SelectedItem="{Binding SelectedItem}"
                         MouseDoubleClick="PlaylistListBox_DoubleClick"
                         AllowDrop="True"
                         Drop="PlaylistListBox_Drop"
                         DragOver="PlaylistListBox_DragOver"
                         PreviewMouseLeftButtonDown="PlaylistListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="PlaylistListBox_PreviewMouseMove"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="FileTypeIcon" Text="🎵" FontSize="{Binding DataContext.PlaylistFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.7" />
                                <TextBlock Grid.Column="1" Text="{Binding FileName}" FontSize="{Binding DataContext.PlaylistFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding Volume, StringFormat={}{0:P0}}" FontSize="9" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="6,0,0,0" Opacity="0.7" />
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Extension}" Value=".mp4"><Setter TargetName="FileTypeIcon" Property="Text" Value="🎬" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".mov"><Setter TargetName="FileTypeIcon" Property="Text" Value="🎬" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".wmv"><Setter TargetName="FileTypeIcon" Property="Text" Value="🎬" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".mkv"><Setter TargetName="FileTypeIcon" Property="Text" Value="🎬" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".jpg"><Setter TargetName="FileTypeIcon" Property="Text" Value="🖼️" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".jpeg"><Setter TargetName="FileTypeIcon" Property="Text" Value="🖼️" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".png"><Setter TargetName="FileTypeIcon" Property="Text" Value="🖼️" /></DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Delete" Click="DeleteMenuItem_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                <!-- Media Controls (bottom of sidebar) -->
                <Border Grid.Row="3" x:Name="MediaControlsContainer" Background="White" Margin="8,6,8,8" Padding="10,8" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <!-- Seek Bar -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding CurrentTimeStr}" FontSize="9" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <Slider x:Name="ProgressSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Progress, Mode=TwoWay}" 
                                    PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp" />
                            <TextBlock Text="{Binding DurationStr}" Grid.Column="2" FontSize="9" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </Grid>

                        <!-- Transport Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding PlayCommand}" 
                                    ToolTip="Play Current Media"
                                    Background="{StaticResource ActionBrush}" BorderThickness="0" Width="34" Height="34" Padding="0" Margin="0,0,4,0">
                                <Border CornerRadius="17">
                                    <Path Data="{StaticResource PlayIconData}" Fill="White" Stretch="Uniform" Width="12" Height="12" Margin="2,0,0,0" />
                                </Border>
                            </Button>
                            <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding PauseCommand}" 
                                    ToolTip="Pause Media"
                                    Background="{StaticResource ActionBrush}" BorderThickness="0" Width="26" Height="26" Padding="0" Margin="0,0,4,0">
                                <Border CornerRadius="13">
                                    <Path Data="{StaticResource PauseIconData}" Fill="White" Stretch="Uniform" Width="9" Height="9" />
                                </Border>
                            </Button>
                            <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding StopCommand}" 
                                    ToolTip="Stop Media"
                                    Background="{StaticResource ActionBrush}" BorderThickness="0" Width="26" Height="26" Padding="0" Margin="0,0,4,0">
                                <Border CornerRadius="13">
                                    <Path Data="{StaticResource StopIconData}" Fill="White" Stretch="Uniform" Width="9" Height="9" />
                                </Border>
                            </Button>
                            <Button Style="{StaticResource ModernButtonStyle}" Click="AmenButton_Click" 
                                    ToolTip="Stop Media &amp; Play Amen Resolve"
                                    Background="#E8B849" BorderThickness="0" Width="44" Height="26" Padding="0">
                                <Border CornerRadius="13">
                                    <TextBlock Text="AMEN" FontSize="7" FontWeight="Black" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                            </Button>
                        </StackPanel>

                        <!-- Title + Volume -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding CurrentMediaTitle}" FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="🔊" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.6" />
                                <Slider x:Name="MediaVolumeSlider" Width="70" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding VolumePercentage}" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0" Width="26" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Resizable splitter -->
        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False"
                      Background="#DDDDDD"
                      Cursor="SizeWE"
                      ToolTip="Drag to resize">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="#BBBBBB"
                            BorderThickness="1,0">
                        <!-- Three dot grip indicator centered on the bar -->
                        <ItemsControl HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <Ellipse Width="3" Height="3" Fill="#999999" Margin="0,2"/>
                            <Ellipse Width="3" Height="3" Fill="#999999" Margin="0,2"/>
                            <Ellipse Width="3" Height="3" Fill="#999999" Margin="0,2"/>
                        </ItemsControl>
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- ═══════════════════════ MAIN CONTENT ═══════════════════════ -->
        <Grid Grid.Column="2" Background="#F0F2F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />    <!-- Preview -->
                <RowDefinition Height="Auto" /> <!-- Controls Area -->
            </Grid.RowDefinitions>

            <!-- Preview Area -->
            <Border Grid.Row="0" Margin="20,20,20,10" CornerRadius="12" Background="Black" ClipToBounds="True">
                <Grid>
                    <!-- Background when playing -->
                    <Border x:Name="PlayIndicator" Opacity="0" BorderBrush="{StaticResource AccentBrush}" BorderThickness="3" CornerRadius="12" Panel.ZIndex="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    
                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                    
                    <!-- Content Type Label -->
                    <Border Background="#44000000" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15" Padding="8,4" CornerRadius="15">
                        <TextBlock x:Name="PreviewLabel" Text="Live Output" Foreground="White" FontSize="10" FontWeight="Bold" />
                    </Border>
                </Grid>
            </Border>

            <!-- Controls Area -->
            <StackPanel Grid.Row="1" Margin="20,0,20,10">
                <!-- Selected Item Volume Editor -->
                <Border Background="White" CornerRadius="12" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🎵" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.6" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Selected Item Volume:" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Slider x:Name="SelectedItemVolumeSlider" Width="120" Minimum="0" Maximum="1" VerticalAlignment="Center" ValueChanged="SelectedItemVolumeSlider_ValueChanged" SmallChange="0.05" />
                            <TextBlock x:Name="SelectedItemVolumeText" Text="80%" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" Width="30" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Playlist Controls + Remote -->
                <Border Margin="0,8,0,0" Background="White" CornerRadius="12" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <!-- Header row: label + remote -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="📂 PLAYLIST CONTROLS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />

                        <!-- Remote Control (right side) -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="12,0,0,6">
                            <TextBlock Text="📱" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.5" />
                            <Border Background="White" Padding="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                <Image x:Name="RemoteQrImage" Width="36" Height="36" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            </Border>
                            <TextBlock x:Name="RemoteUrlText" Text="Starting..." FontSize="8" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>

                        <!-- Playlist Buttons -->
                        <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="3">
                            <Button Style="{StaticResource ModernButtonStyle}" Click="LoadPlaylist_Click" Content="LOAD" 
                                    ToolTip="Load Saved Playlist"
                                    Margin="0,0,2,2" Height="22" FontSize="8" Padding="2,0" />
                            <Button Style="{StaticResource ModernButtonStyle}" Click="SavePlaylist_Click" Content="SAVE" 
                                    ToolTip="Save Current Playlist"
                                    Margin="0,0,2,2" Height="22" FontSize="8" Padding="2,0" />
                            <Button Style="{StaticResource ModernButtonStyle}" Click="CreatePlaylist_Click" Content="NEW" 
                                    ToolTip="Create Service Plan"
                                    Margin="0,0,0,2" Height="22" FontSize="8" Padding="2,0" />
                            <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding BlankCommand}" Content="BLANK" Margin="0,0,2,0" Height="22" FontSize="8" Padding="2,0" />
                            <Button Style="{StaticResource PrimaryButtonStyle}" Click="ToggleDisplay_Click" Content="DISPLAY" Grid.ColumnSpan="2" Height="22" FontSize="8" Padding="2,0" />
                            <Button Style="{StaticResource ModernButtonStyle}" Click="ClosePlaylist_Click" Content="CLOSE PLAYLIST" 
                                    ToolTip="Close Current Playlist"
                                    Grid.ColumnSpan="3" Height="22" FontSize="8" Padding="2,0" Margin="0,2,0,0" />
                        </UniformGrid>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
