<Window x:Class="ChurchDisplayApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Church Display Control"
        Height="700"
        Width="1200"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        Icon="icon.ico">

    <Window.InputBindings>
        <KeyBinding Key="Space" Command="{Binding NextCommand}" />
        <KeyBinding Key="Right" Command="{Binding NextCommand}" />
        <KeyBinding Key="Left" Command="{Binding PreviousCommand}" />
        <KeyBinding Key="B" Command="{Binding BlankCommand}" />
        <KeyBinding Key="F11" Command="{Binding ToggleFullscreenCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ExitFullscreenCommand}" />
    </Window.InputBindings>
    
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280" MinWidth="160" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" MinWidth="360" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Add Button -->
                    <RowDefinition Height="Auto" /> <!-- Section Label -->
                    <RowDefinition Height="*" />    <!-- Playlist -->
                </Grid.RowDefinitions>

                <Button Grid.Row="0" 
                        Style="{StaticResource ModernButtonStyle}" 
                        Click="AddFiles_Click"
                        Margin="15,5" 
                        Padding="8,4"
                        HorizontalAlignment="Stretch"
                        Height="32">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource AddFilesIconData}" Fill="{StaticResource TextBrush}" Stretch="Uniform" Width="10" Height="10" Margin="0,0,8,0" />
                        <TextBlock Text="ADD MEDIA" FontSize="10" FontWeight="Bold" />
                    </StackPanel>
                </Button>

                <DockPanel Grid.Row="1" Margin="15,10,15,5">
                    <TextBlock Text="SERVICE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="A" FontSize="8" VerticalAlignment="Center" Opacity="0.5" Margin="0,0,4,0" />
                        <Slider Width="50" Minimum="6" Maximum="24" Value="{Binding PlaylistFontSize, Mode=TwoWay}" VerticalAlignment="Center" SmallChange="1" />
                        <TextBlock Text="A" FontSize="12" VerticalAlignment="Center" Opacity="0.8" Margin="4,0,0,0" />
                    </StackPanel>
                </DockPanel>

                <ListBox x:Name="PlaylistListBox"
                         Grid.Row="2"
                         ItemsSource="{Binding PlaylistItems}"
                         SelectedItem="{Binding SelectedItem}"
                         MouseDoubleClick="PlaylistListBox_DoubleClick"
                         AllowDrop="True"
                         Drop="PlaylistListBox_Drop"
                         DragOver="PlaylistListBox_DragOver"
                         PreviewMouseLeftButtonDown="PlaylistListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="PlaylistListBox_PreviewMouseMove"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="FileTypeIcon" Text="🎵" FontSize="{Binding DataContext.PlaylistFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.7" />
                                <TextBlock Grid.Column="1" Text="{Binding FileName}" FontSize="{Binding DataContext.PlaylistFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Extension}" Value=".mp4"><Setter TargetName="FileTypeIcon" Property="Text" Value="🎬" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".mov"><Setter TargetName="FileTypeIcon" Property="Text" Value="🎬" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".wmv"><Setter TargetName="FileTypeIcon" Property="Text" Value="🎬" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".mkv"><Setter TargetName="FileTypeIcon" Property="Text" Value="🎬" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".jpg"><Setter TargetName="FileTypeIcon" Property="Text" Value="🖼️" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".jpeg"><Setter TargetName="FileTypeIcon" Property="Text" Value="🖼️" /></DataTrigger>
                                <DataTrigger Binding="{Binding Extension}" Value=".png"><Setter TargetName="FileTypeIcon" Property="Text" Value="🖼️" /></DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Delete" Click="DeleteMenuItem_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
                <!-- Remote Control (Bottom of Sidebar) -->
                <Border Grid.Row="2" VerticalAlignment="Bottom" Background="White" Margin="10" Padding="10" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📱 REMOTE CONTROL" FontSize="9" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="White" Padding="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Image x:Name="RemoteQrImage" Width="60" Height="60" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            </Border>
                            <TextBlock x:Name="RemoteUrlText" Grid.Column="1" Text="Starting..." FontSize="10" TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource MutedTextBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Resizable splitter -->
        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False"
                      Background="#DDDDDD"
                      Cursor="SizeWE"
                      ToolTip="Drag to resize">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="#BBBBBB"
                            BorderThickness="1,0">
                        <!-- Three dot grip indicator centered on the bar -->
                        <ItemsControl HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <Ellipse Width="3" Height="3" Fill="#999999" Margin="0,2"/>
                            <Ellipse Width="3" Height="3" Fill="#999999" Margin="0,2"/>
                            <Ellipse Width="3" Height="3" Fill="#999999" Margin="0,2"/>
                        </ItemsControl>
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- Main Content -->
        <Grid Grid.Column="2" Background="#F0F2F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />    <!-- Preview -->
                <RowDefinition Height="Auto" /> <!-- Controls Area -->
            </Grid.RowDefinitions>

            <!-- Preview Area -->
            <Border Grid.Row="0" Margin="20,20,20,10" CornerRadius="12" Background="Black" ClipToBounds="True">
                <Grid>
                    <!-- Background when playing -->
                    <Border x:Name="PlayIndicator" Opacity="0" BorderBrush="{StaticResource AccentBrush}" BorderThickness="3" CornerRadius="12" Panel.ZIndex="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    
                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                    
                    <!-- Content Type Label -->
                    <Border Background="#44000000" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15" Padding="8,4" CornerRadius="15">
                        <TextBlock x:Name="PreviewLabel" Text="{Binding CurrentMediaType}" Foreground="White" FontSize="10" FontWeight="Bold" />
                    </Border>
                </Grid>
            </Border>

            <!-- Controls Area -->
            <StackPanel Grid.Row="1" Margin="20,0,20,10">
                <!-- Compact Playback Bar -->
                <Border x:Name="MediaControlsContainer" Background="White" CornerRadius="12" Padding="15,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <!-- Seek Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding CurrentTimeStr}" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Slider x:Name="ProgressSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Progress, Mode=TwoWay}" 
                                    PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp" />
                            <TextBlock Text="{Binding DurationStr}" Grid.Column="2" FontSize="10" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </Grid>

                        <!-- Control Buttons and Status -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /> <!-- Prev/Play/Next -->
                                <ColumnDefinition Width="*" />    <!-- Title -->
                                <ColumnDefinition Width="Auto" /> <!-- Volume -->
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding PlayCommand}" 
                                        ToolTip="Play Current Media (Space)"
                                        Background="{StaticResource ActionBrush}" BorderThickness="0" Width="38" Height="38" Padding="0" Margin="0,0,6,0">
                                    <Border CornerRadius="19">
                                        <Path Data="{StaticResource PlayIconData}" Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="3,0,0,0" />
                                    </Border>
                                </Button>
                                <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding PauseCommand}" 
                                        ToolTip="Pause Media"
                                        Background="{StaticResource ActionBrush}" BorderThickness="0" Width="28" Height="28" Padding="0" Margin="0,0,6,0">
                                    <Border CornerRadius="14">
                                        <Path Data="{StaticResource PauseIconData}" Fill="White" Stretch="Uniform" Width="10" Height="10" />
                                    </Border>
                                </Button>
                                <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding StopCommand}" 
                                        ToolTip="Stop Media"
                                        Background="{StaticResource ActionBrush}" BorderThickness="0" Width="28" Height="28" Padding="0">
                                    <Border CornerRadius="14">
                                        <Path Data="{StaticResource StopIconData}" Fill="White" Stretch="Uniform" Width="10" Height="10" />
                                    </Border>
                                </Button>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{Binding CurrentMediaTitle}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0" TextTrimming="CharacterEllipsis" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="🔊" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.6" />
                                <Slider x:Name="MediaVolumeSlider" Width="80" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding VolumePercentage}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" Width="30" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Bottom Actions Grid (Parallel Playlist Management and BGM) -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Playlist Management Section (Primary Actions) -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="8,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,4,0">
                        <StackPanel>
                            <TextBlock Text="📂 PLAYLIST ACTIONS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                            <UniformGrid Columns="3">
                                <Button Style="{StaticResource ModernButtonStyle}" Click="LoadPlaylist_Click" Content="LOAD" 
                                        ToolTip="Load Saved Playlist"
                                        Margin="0,0,2,2" Height="22" FontSize="8" Padding="2,0" />
                                <Button Style="{StaticResource ModernButtonStyle}" Click="SavePlaylist_Click" Content="SAVE" 
                                        ToolTip="Save Current Playlist"
                                        Margin="0,0,2,2" Height="22" FontSize="8" Padding="2,0" />
                                <Button Style="{StaticResource ModernButtonStyle}" Click="CreatePlaylist_Click" Content="NEW" 
                                        ToolTip="Create Service Plan"
                                        Margin="0,0,0,2" Height="22" FontSize="8" Padding="2,0" />
                                <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding BlankCommand}" Content="BLANK" Margin="0,0,2,0" Height="22" FontSize="8" Padding="2,0" />
                                <Button Style="{StaticResource PrimaryButtonStyle}" Click="ToggleDisplay_Click" Content="DISPLAY" Grid.ColumnSpan="2" Height="22" FontSize="8" Padding="2,0" />
                                <Button Style="{StaticResource ModernButtonStyle}" Click="ClosePlaylist_Click" Content="CLOSE PLAYLIST" 
                                        ToolTip="Close Current Playlist"
                                        Grid.ColumnSpan="3" Height="22" FontSize="8" Padding="2,0" Margin="0,2,0,0" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Background Music Section (Secondary Actions) -->
                    <Border x:Name="BackgroundMusicGroupBox" Grid.Column="1" Background="White" CornerRadius="12" Padding="8,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <!-- Header with Volume -->
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="🎵 BACKGROUND MUSIC" FontSize="9" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="🔊" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6" />
                                    <Slider x:Name="BackgroundMusicVolumeSlider" Width="60" Minimum="0" Maximum="1" Value="0.3" VerticalAlignment="Center" ValueChanged="BackgroundMusicVolume_ValueChanged" />
                                    <TextBlock x:Name="BackgroundMusicVolumeText" Text="30%" FontSize="8" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0" Width="22" />
                                </StackPanel>
                            </DockPanel>

                            <!-- Standard BGM Control -->
                            <Border Background="#FDFDFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6,2" Margin="0,0,0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#F8F9FA" Padding="4,1" CornerRadius="3">
                                            <TextBlock Text="INTRO" FontSize="8" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                                        </Border>
                                        <Button Click="SelectStandardMusic_Click" Style="{StaticResource ModernButtonStyle}" BorderThickness="0" Padding="3,0" Margin="2,0,0,0" MinWidth="18">
                                            <Path Data="{StaticResource ChevronDownData}" Fill="{StaticResource ActionBrush}" Stretch="Uniform" Width="6" Height="3" />
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding IntroBGMName}" Margin="6,0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="10" TextTrimming="CharacterEllipsis" />
                                    
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Click="BackgroundMusicPlayStandard_Click" Style="{StaticResource ModernButtonStyle}" 
                                                ToolTip="Play Standard BGM"
                                                BorderThickness="0" Padding="4,2" Margin="0,0,2,0" MinWidth="22">
                                            <Path Data="{StaticResource PlayIconData}" Fill="{StaticResource ActionBrush}" Stretch="Uniform" Width="8" Height="8" />
                                        </Button>
                                        <Button Click="BackgroundMusicPause_Click" Style="{StaticResource ModernButtonStyle}" BorderThickness="0" Padding="4,2" Margin="0,0,2,0" MinWidth="22">
                                            <TextBlock Text="⏸" FontSize="9" FontWeight="Bold" Foreground="{StaticResource ActionBrush}" VerticalAlignment="Center" />
                                        </Button>
                                        <Button Click="BackgroundMusicStop_Click" Style="{StaticResource ModernButtonStyle}" 
                                                ToolTip="Stop with Amen Resolve"
                                                BorderThickness="0" Padding="4,2" MinWidth="22">
                                            <TextBlock Text="AMEN" FontSize="7" FontWeight="Black" Foreground="{StaticResource ActionBrush}" VerticalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Kids BGM Control -->
                            <Border Background="#FDFDFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#F8F9FA" Padding="4,1" CornerRadius="3">
                                            <TextBlock Text="KIDS" FontSize="8" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                                        </Border>
                                        <Button Click="SelectChildSermonMusic_Click" Style="{StaticResource ModernButtonStyle}" BorderThickness="0" Padding="3,0" Margin="2,0,0,0" MinWidth="18">
                                            <Path Data="{StaticResource ChevronDownData}" Fill="{StaticResource ActionBrush}" Stretch="Uniform" Width="6" Height="3" />
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding KidsBGMName}" Margin="6,0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="10" TextTrimming="CharacterEllipsis" />
                                    
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Click="BackgroundMusicPlayChildrensSermon_Click" Style="{StaticResource ModernButtonStyle}" 
                                                ToolTip="Play Kids BGM"
                                                BorderThickness="0" Padding="4,2" Margin="0,0,2,0" MinWidth="22">
                                            <Path Data="{StaticResource PlayIconData}" Fill="{StaticResource ActionBrush}" Stretch="Uniform" Width="8" Height="8" />
                                        </Button>
                                        <Button Click="BackgroundMusicPause_Click" Style="{StaticResource ModernButtonStyle}" BorderThickness="0" Padding="4,2" Margin="0,0,2,0" MinWidth="22">
                                            <TextBlock Text="⏸" FontSize="9" FontWeight="Bold" Foreground="{StaticResource ActionBrush}" VerticalAlignment="Center" />
                                        </Button>
                                        <Button Click="BackgroundMusicStop_Click" Style="{StaticResource ModernButtonStyle}" BorderThickness="0" Padding="4,2" MinWidth="22">
                                            <TextBlock Text="AMEN" FontSize="7" FontWeight="Black" Foreground="{StaticResource ActionBrush}" VerticalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
