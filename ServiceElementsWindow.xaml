<Window x:Class="ChurchDisplayApp.ServiceElementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Service Elements"
        Width="680" Height="620"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>

        <!-- Red label style for missing files -->
        <Style x:Key="MissingFileLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Text" Value="File not found — cleared"/>
        </Style>

        <!-- Normal label style for assigned files -->
        <Style x:Key="AssignedFileLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="DarkGreen"/>
            <Setter Property="FontStyle" Value="Normal"/>
        </Style>

        <!-- No file style -->
        <Style x:Key="NoFileLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Text" Value="No file selected"/>
        </Style>

    </Window.Resources>

    <DockPanel Margin="8">

        <!-- Bottom action bar -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,8,0,0">
            <DockPanel>
                <!-- Left side: gear button + volume -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SettingsButton"
                            Content="⚙ Settings"
                            MinWidth="90" Padding="8,4"
                            Click="Settings_Click"
                            ToolTip="Add, remove, or rename slots and set the default search folder"/>
                    <TextBlock Text="🔊" FontSize="12" VerticalAlignment="Center" Margin="10,0,4,0" Opacity="0.6" />
                    <Slider x:Name="DefaultVolumeSlider" Width="80" Minimum="0" Maximum="1" Value="0.8" VerticalAlignment="Center" SmallChange="0.05" ToolTip="Default volume for items added to playlist (saved between sessions)" ValueChanged="DefaultVolumeSlider_ValueChanged" />
                    <TextBlock x:Name="DefaultVolumeText" Text="80%" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0" Width="30" />
                </StackPanel>

                <!-- Right side: action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MakeServiceButton" Content="▶ Send to Playlist" MinWidth="110" Padding="8,4" Margin="4,0" Click="MakeService_Click"
                            Background="#2E7D32" Foreground="White" FontWeight="Bold"
                            ToolTip="Add all assigned slots to the playlist in order"/>
                    <Button x:Name="CloseButton"      Content="Close"        MinWidth="70" Padding="8,4" Margin="4,0" Click="Close_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Slot list header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>  <!-- Slot name -->
                <ColumnDefinition Width="*"/>    <!-- File label -->
                <ColumnDefinition Width="70"/>   <!-- Select -->
                <ColumnDefinition Width="55"/>   <!-- Clear -->
                <ColumnDefinition Width="50"/>   <!-- Use -->
                <ColumnDefinition Width="80"/>   <!-- Remember -->
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Slot"         FontWeight="Bold" Margin="4,0"/>
            <TextBlock Grid.Column="1" Text="File"         FontWeight="Bold" Margin="4,0"/>
            <TextBlock Grid.Column="4" Text="Add"          FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="Remember"     FontWeight="Bold" HorizontalAlignment="Center"/>
        </Grid>

        <!-- Scrollable slot list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ContentControl x:Name="SlotListControl"/>
        </ScrollViewer>

    </DockPanel>
</Window>
